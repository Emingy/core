{
    "extends": "@emingy/configs/tsconfig",
    "compilerOptions": {
        "paths": {
            "@emingy/core/*": ["src/*"],
            "@storybook-components/*": [".storybook/components/*"],
            "@storybook-utils/*": [".storybook/utils/*"]
        },
        "baseUrl": "./",
        "rootDir": "./src",
        "noEmit": true,
        "module": "es2015",
        "moduleResolution": "bundler"
    },
    "include": ["src/**/*"],
    "exclude": ["lib", "node_modules", ".storybook", "src/styles", "**/*.spec.*"]
}
